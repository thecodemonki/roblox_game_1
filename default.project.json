    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0.45,
          0.48,
          0.38
        ],
        "Brightness": 1.65,
        "ColorShift_Top": [
          0.52,
          0.55,
          0.42
        ],
        "OutdoorAmbient": [
          0.42,
          0.46,
          0.38
        ],
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
